# API test environment example (DEV-87).
# Copy to api/.env.test for local integration e2e against Docker Postgres.
# .env.test is gitignored — never commit secrets or real API keys.
#
#   cp .env.test.example .env.test
#   docker compose up -d   # from repo root
#   cd api && npx prisma migrate deploy && npm run test:e2e
#
# Security notes:
# - PostgreSQL only (ADR-003). SQLite DSNs are rejected by test helpers.
# - API_NINJAS_KEY below is a placeholder — default suites mock the upstream client.

# Same shape as production DATABASE_URL.
DATABASE_URL=postgresql://gad:gad@localhost:5432/global_analytics

# Optional explicit override read by ensureTestEnv().
# TEST_DATABASE_URL=postgresql://gad:gad@localhost:5432/global_analytics

NODE_ENV=test
PORT=3001

# Placeholder only — must NOT be used for live HTTP calls in CI.
API_NINJAS_KEY=test-key-not-for-live-calls
