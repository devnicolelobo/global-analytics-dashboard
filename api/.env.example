# Global Analytics Dashboard — API
# Copy to .env and fill in values. Never commit .env.
#
#   cp .env.example .env

# ── Application ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────
# Required — start locally: docker compose up -d  (from repo root)
DATABASE_URL=postgresql://gad:gad@localhost:5432/global_analytics

# ── External APIs (server-only — never expose to web/) ───────
# Primary provider — https://api-ninjas.com/api/covid19
API_NINJAS_KEY=
# Optional HTTP timeout in ms (1000–60000). Default: 15000
# API_NINJAS_TIMEOUT_MS=15000

# ── CORS (browser clients, e.g. Next.js on :3000) ────────────
# Comma-separated origins. Default when unset: http://localhost:3000
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Contingency provider (optional)
# APIFY_TOKEN=
