# Global Analytics Dashboard — API
# Copy to .env and fill in values. Never commit .env.
#
#   cp .env.example .env

# ── Application ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────
# Start locally: docker compose up -d  (from repo root)
DATABASE_URL=postgresql://gad:gad@localhost:5432/global_analytics

# ── External APIs (server-only — never expose to web/) ───────
# Primary provider — https://api-ninjas.com/api/covid19
API_NINJAS_KEY=

# Contingency provider (optional — Phase 3+)
# APIFY_TOKEN=
